-- NOVO: Spinbot
spinbotSpeed = 500 -- Velocidade MAIS SUAVE (Pedida pelo usuГѓВЎrio)
spinbotToggle = createToggle(combatContent, "Spinbot (Anti-Aim)", function(enabled)
	if enabled then
		_G.spinAngle = 0
		_G.spinLoop = RunService.RenderStepped:Connect(function()
			local char = LocalPlayer.Character
			if char and char:FindFirstChild("HumanoidRootPart") then
				local hum = char:FindFirstChild("Humanoid")
				local root = char.HumanoidRootPart
				if hum then
					-- SГѓвЂњ ATIVA QUANDO O ROUND COMEГѓвЂЎA (WalkSpeed > 0)
					if hum.WalkSpeed <= 0 then
						hum.AutoRotate = true
						return
					end

					hum.AutoRotate = false -- Previne a tentativa de ficar de pГѓВ© da engine
					if hum.FloorMaterial ~= Enum.Material.Air then
						hum.Jump = true -- ForГѓВ§a a saltar normal
					else
						-- BHOP CS2: Puxado para o chГѓВЈo suavemente na queda
						local vel = root.AssemblyLinearVelocity
						if vel.Y <= 0 then
							root.AssemblyLinearVelocity = Vector3.new(vel.X, vel.Y - 2, vel.Z)
						end
					end
					
					-- Andar mais rГѓВЎpido enquanto gira (CFrame Speed EQUILIBRADO)
					if hum.MoveDirection.Magnitude > 0 then
						local rayParams = RaycastParams.new()
						rayParams.FilterDescendantsInstances = {char}
						rayParams.FilterType = Enum.RaycastFilterType.Exclude
						
						-- Verificar se hГѓВЎ uma parede/barreira no caminho antes de teleportar
						local rayResult = workspace:Raycast(root.Position, hum.MoveDirection * 2, rayParams)
						if not rayResult then
							root.CFrame = root.CFrame + (hum.MoveDirection * 0.15)
						end
					end
				end
				
				-- RotaГѓВ§ГѓВЈo Pura, MatemГѓВЎtica (ImpossГѓВ­vel de deitar ou bugar fГѓВ­sica)
				_G.spinAngle = _G.spinAngle + spinbotSpeed
				if _G.spinAngle >= 360 then _G.spinAngle = _G.spinAngle - 360 end
				
				-- MantГѓВ©m a posiГѓВ§ГѓВЈo (com o offset de movimento aplicado acima) rodado no eixo Y
				root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(_G.spinAngle), 0)
			end
		end)
	else
		if _G.spinLoop then _G.spinLoop:Disconnect() end
		
		-- Restaurar estado natural do personagem
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("Humanoid") then
			char.Humanoid.AutoRotate = true
		end
	end
end, "Spins your character quickly to throw off enemy aim.", {
	bindId = "spinbot",
	getBindValue = function() return spinbotBind end,
	getBindName = function() return spinbotBindString end,
	setBind = function(bindValue, bindName)
		spinbotBind = bindValue
		spinbotBindString = bindDisplayName(bindValue, bindName)
	end,
})

