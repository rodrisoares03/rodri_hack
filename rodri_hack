function setTab(tabName)
	for name, tabData in pairs(tabs) do
		local tab, icon, label = tabData[1], tabData[2], tabData[3]
		local indicator = tabData[5]
		if name == tabName then
			UI_Tween(tab, {BackgroundColor3 = C.ActiveTabBg, BackgroundTransparency = 0}, 0.2)
			UI_Tween(icon, {TextColor3 = C.TxtWhite}, 0.2)
			label.Font = Enum.Font.GothamBold
			UI_Tween(label, {TextColor3 = C.TxtWhite}, 0.2)
			if indicator then indicator.Visible = true indicator.BackgroundTransparency = 0 end
			pages[name].Visible = true
			pages[name].CanvasPosition = Vector2.new(0, 0)
			currentTab = name
		else
			UI_Tween(tab, {BackgroundTransparency = 0.5, BackgroundColor3 = C.BgSidebar}, 0.2)
			UI_Tween(icon, {TextColor3 = C.TxtWhite}, 0.2)
			label.Font = Enum.Font.Gotham
			UI_Tween(label, {TextColor3 = C.TxtWhite}, 0.2)
			if indicator then indicator.Visible = false indicator.BackgroundTransparency = 1 end
			pages[name].Visible = false
		end
	end

	if tabName == "UTIL" then
		task.defer(function()
			bindAutoSize(movementSubCategory, movementLayout)
			bindAutoSize(boostsSubCategory, boostsLayout)
			bindAutoSize(utilsSubCategory, utilsLayout)
			refreshUtilCanvas()
		end)
	end
end
