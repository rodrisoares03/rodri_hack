_G.hitboxIndicators = {} -- Indicadores visuais separados (nГѓВЈo deforma o personagem)

local function expandCharacterHitbox(character)
	if not character or not character.Parent then return end

	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Guardar tamanho original do Root
	if not _G.hitboxOriginalSizes[character] then
		_G.hitboxOriginalSizes[character] = {
			Size = root.Size,
			Transparency = root.Transparency,
			Material = root.Material,
		}
	end

	-- Expandir APENAS o HumanoidRootPart (ГѓВ© invisГѓВ­vel, nГѓВЈo deforma o modelo)
	root.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
	root.Transparency = 1 -- SEMPRE invisГѓВ­vel (o Root nГѓВЈo deve ser visГѓВ­vel)
	root.CanCollide = false

	-- Indicador visual com BORDAS marcadas (visГѓВ­vel atravГѓВ©s de paredes)
	if _G.hitboxVisible then
		local indicator = _G.hitboxIndicators[character]
		if not indicator or not indicator.Parent then
			-- Part invisГѓВ­vel (sГѓВі serve de base para as bordas)
			indicator = Instance.new("Part")
			indicator.Name = "HitboxIndicator"
			indicator.Anchored = true
			indicator.CanCollide = false
			indicator.CanQuery = false -- Raycasts/tiros passam atravГѓВ©s (acertam no Root real)
			indicator.Shape = Enum.PartType.Block
			indicator.Transparency = 1 -- Part totalmente invisГѓВ­vel
			indicator.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
			indicator.Parent = workspace

			-- BORDAS 3D com Highlight (contorno brilhante, sem preenchimento)
			local highlight = Instance.new("Highlight")
			highlight.Name = "HitboxOutline"
			highlight.Adornee = indicator
			highlight.FillTransparency = 1 -- SEM preenchimento (limpo)
			highlight.OutlineTransparency = 0 -- Bordas 100% visГѓВ­veis
			highlight.OutlineColor = _G.hitboxColor
			highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			highlight.Parent = indicator

			-- SelectionBox para bordas 3D extras (wireframe grosso)
			local selBox = Instance.new("SelectionBox")
			selBox.Name = "HitboxWireframe"
			selBox.Adornee = indicator
			selBox.Color3 = _G.hitboxColor
			selBox.LineThickness = 0.04
			selBox.SurfaceTransparency = 1 -- Sem faces, sГѓВі arestas
			selBox.Parent = indicator

			_G.hitboxIndicators[character] = indicator
		end
		-- Atualizar posiГѓВ§ГѓВЈo, tamanho e cor a cada frame
		indicator.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
		indicator.CFrame = root.CFrame

		-- Atualizar cores das bordas
		local hl = indicator:FindFirstChild("HitboxOutline")
		if hl then hl.OutlineColor = _G.hitboxColor end
		local sb = indicator:FindFirstChild("HitboxWireframe")
		if sb then sb.Color3 = _G.hitboxColor end
	else
		-- Sem indicador visual
		if _G.hitboxIndicators[character] then
			pcall(function() _G.hitboxIndicators[character]:Destroy() end)
			_G.hitboxIndicators[character] = nil
		end
	end
end

local function restoreCharacterHitbox(character)
	if not character then return end

	-- Restaurar Root
	local root = character:FindFirstChild("HumanoidRootPart")
	if root then
		local originals = _G.hitboxOriginalSizes[character]
		if originals then
			root.Size = originals.Size
			root.Transparency = originals.Transparency
			root.Material = originals.Material
		else
			root.Size = Vector3.new(2, 2, 1)
			root.Transparency = 1
			root.Material = Enum.Material.Plastic
		end
	end

	-- Remover indicador visual
	if _G.hitboxIndicators[character] then
		pcall(function() _G.hitboxIndicators[character]:Destroy() end)
		_G.hitboxIndicators[character] = nil
	end

	_G.hitboxOriginalSizes[character] = nil
end

hitboxToggle = createToggle(combatContent, "Hitbox Expander", function(enabled)
	if enabled then
		_G.hitboxLoop = RunService.RenderStepped:Connect(function()
			for _, player in pairs(Players:GetPlayers()) do
				pcall(function()
					if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
						local hum = player.Character:FindFirstChildOfClass("Humanoid")
						local isDead = not hum or hum.Health <= 0

						if not isDead and isInSameDimension(player.Character) then
							expandCharacterHitbox(player.Character)
						else
							-- Morto, outra dimensГѓВЈo, ou sem humanoid: limpar
							restoreCharacterHitbox(player.Character)
						end
					end
				end)
			end

			-- Limpar indicadores de personagens que jГѓВЎ nГѓВЈo existem ou morreram
			for char, indicator in pairs(_G.hitboxIndicators) do
				local shouldClean = not char or not char.Parent or not char:FindFirstChild("HumanoidRootPart")
				if not shouldClean then
					local hum = char:FindFirstChildOfClass("Humanoid")
					if not hum or hum.Health <= 0 then shouldClean = true end
				end
				if shouldClean then
					pcall(function() indicator:Destroy() end)
					_G.hitboxIndicators[char] = nil
					_G.hitboxOriginalSizes[char] = nil
				end
			end
		end)

		-- Limpar hitbox quando jogador sai do jogo
		_G.hitboxPlayerRemovingConn = Players.PlayerRemoving:Connect(function(player)
			if player and player.Character then
				restoreCharacterHitbox(player.Character)
			end
			-- Limpar por seguranГѓВ§a (character pode jГѓВЎ ter sido destruГѓВ­do)
			for char, indicator in pairs(_G.hitboxIndicators) do
				if not char or not char.Parent then
					pcall(function() indicator:Destroy() end)
					_G.hitboxIndicators[char] = nil
					_G.hitboxOriginalSizes[char] = nil
				end
			end
		end)
	else
		if _G.hitboxLoop then _G.hitboxLoop:Disconnect() end
		if _G.hitboxPlayerRemovingConn then _G.hitboxPlayerRemovingConn:Disconnect() end
		for _, player in pairs(Players:GetPlayers()) do
			pcall(function()
				if player ~= LocalPlayer and player.Character then
					restoreCharacterHitbox(player.Character)
				end
			end)
		end
		_G.hitboxOriginalSizes = {}
		-- Limpar todos os indicadores
		for char, indicator in pairs(_G.hitboxIndicators) do
			pcall(function() indicator:Destroy() end)
		end
		_G.hitboxIndicators = {}
	end
end, "Expands the enemy hitbox from the root part only.", {
