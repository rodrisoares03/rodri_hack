			Name = "InlineHint",
			BackgroundColor3 = Color3.fromRGB(0, 0, 0),
			BackgroundTransparency = 0.08,
			Position = UDim2.new(0, 0, 0, 0),
			Size = UDim2.new(0, 320, 0, 24),
			AnchorPoint = Vector2.new(0, 0),
			Font = Enum.Font.Gotham,
