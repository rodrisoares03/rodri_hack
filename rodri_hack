-- FunГѓВ§ГѓВЈo para verificar se estГѓВЎ na mesma dimensГѓВЈo/mapa
function isInSameDimension(targetCharacter)
	local myChar = LocalPlayer.Character
	if not myChar or not targetCharacter then return false end
	
	-- Apenas verificamos a distancia para evitar a quebra em jogos que separam players por Pastas/Times
	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	local targetRoot = targetCharacter:FindFirstChild("HumanoidRootPart")
	
	if not myRoot or not targetRoot then return false end
	
	-- Se a distГѓВўncia for absurdamente grande (>10000), provavelmente estГѓВЈo em dimensГѓВµes diferentes
	local distance = (targetRoot.Position - myRoot.Position).Magnitude
	if distance > 10000 then return false end
	
	return true
end

function isValidPlayer(player)
	local data = ESPData[player]
	if not data then return false end
	if not data.character or not data.humanoid or not data.root then return false end
	if data.humanoid.Health <= 0 then return false end
	return true
end

