-- Box ESP dinГѓВўmica que se adapta ao tamanho real do personagem
function ensureBox3D(character)
	if not character or not character.Parent then
		if boxes[character] then
			pcall(function() boxes[character]:Destroy() end)
			boxes[character] = nil
		end
		return
	end

	-- Verificar se estГѓВЎ na mesma dimensГѓВЈo
	if not isInSameDimension(character) then
		if boxes[character] then
			pcall(function() boxes[character]:Destroy() end)
			boxes[character] = nil
		end
		return
	end

	if not showBox3D or not espEnabled then
		if boxes[character] then
			pcall(function() boxes[character]:Destroy() end)
			boxes[character] = nil
		end
		return
	end
	
	-- Verificar distГѓВўncia
	local myChar = LocalPlayer.Character
	if myChar then
		local myRoot = getPrimaryPart(myChar)
		local targetRoot = getPrimaryPart(character)
		if myRoot and targetRoot then
			local distance = (targetRoot.Position - myRoot.Position).Magnitude
			if distance >= ESP_MAX_DISTANCE then
				if boxes[character] then
					pcall(function() boxes[character]:Destroy() end)
					boxes[character] = nil
				end
				return
			end
		end
	end

	local head = character:FindFirstChild("Head")
	local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
	if not head or not humanoidRootPart then return end

	-- Usar proporГѓВ§ГѓВµes padrГѓВЈo de personagem Roblox (nГѓВЈo ler Size das partes
	-- porque o Hitbox Expander pode ter alterado os tamanhos)
	-- R15: ~5.3 studs de altura, ~2.5 studs de largura
	-- R6: ~5.0 studs de altura, ~2.0 studs de largura
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local isR15 = humanoid and humanoid.RigType == Enum.HumanoidRigType.R15

	local charHeight = isR15 and 5.4 or 5.0 -- Altura padrГѓВЈo do personagem  
	local charWidth = isR15 and 3.2 or 2.8  -- Largura proporcional

	-- Pequeno padding para a box nГѓВЈo ficar colada ao corpo
	charHeight = charHeight + 0.6
	charWidth = charWidth + 0.4

	-- Offset: centralizar a box no corpo (Root fica no centro do torso, nГѓВЈo do corpo inteiro)
	-- A cabeГѓВ§a fica ~1.5 studs acima do root, os pГѓВ©s ~3 studs abaixo
	local offsetY = isR15 and -0.4 or -0.3

	-- Criar BillboardGui se nГѓВЈo existir
	if not boxes[character] then
		local billboard = Instance.new("BillboardGui")
		billboard.Name = "ESP_Box"
		billboard.Adornee = humanoidRootPart
		billboard.Size = UDim2.new(charWidth, 0, charHeight, 0)
		billboard.StudsOffset = Vector3.new(0, offsetY, 0)
		billboard.AlwaysOnTop = true
		billboard.Parent = humanoidRootPart
		
		-- Frame da box
		local frame = Instance.new("Frame")
		frame.Name = "BoxFrame"
		frame.Size = UDim2.new(1, 0, 1, 0)
		frame.BackgroundTransparency = 1
		frame.Parent = billboard
		
		-- Bordas com cantos arredondados
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 3)
		corner.Parent = frame
		
		-- Criar bordas com espessura melhorada
		local stroke = Instance.new("UIStroke")
		stroke.Color = espColor
		stroke.Thickness = 2.5
		stroke.Transparency = 0.1
		stroke.Parent = frame
		
		boxes[character] = billboard
	end
	
	-- Atualizar tamanho e cor dinamicamente
	local billboard = boxes[character]
	if billboard and billboard.Parent then
		billboard.Size = UDim2.new(charWidth, 0, charHeight, 0)
		billboard.StudsOffset = Vector3.new(0, offsetY, 0)
		
		local frame = billboard:FindFirstChild("BoxFrame") or billboard:FindFirstChildOfClass("Frame")
		if frame then
			local stroke = frame:FindFirstChildOfClass("UIStroke")
			if stroke then
				stroke.Color = espColor
			end
		end
	end
end

