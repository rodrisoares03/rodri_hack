-- NOVO: Anti-Ragdoll / Anti-Fling
antiRagdollToggle = createToggle(utilsContent, "Anti-Ragdoll", function(enabled)
	local function applyAntiRagdoll(char)
		local hum = char:FindFirstChild("Humanoid")
		if hum then
			hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, not enabled)
			hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, not enabled)
		end
		for _, part in pairs(char:GetChildren()) do
			if part:IsA("BasePart") then
				if enabled then
					part.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
				else
					part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
				end
			end
		end
	end
	if enabled then
		if LocalPlayer.Character then applyAntiRagdoll(LocalPlayer.Character) end
		_G.antiRagdollConn = LocalPlayer.CharacterAdded:Connect(function(newChar)
			task.wait(1)
			applyAntiRagdoll(newChar)
		end)
	else
		if _G.antiRagdollConn then _G.antiRagdollConn:Disconnect() end
		if LocalPlayer.Character then applyAntiRagdoll(LocalPlayer.Character) end
	end
end, "Stops your character from falling into ragdoll and removes extra friction.")

-- Redimensionar UI (estilo Solix: mainFrame 960x600, topbar 38, sidebar 185)
function resizeUI(newWidth, newHeight)
	mainFrame.Position = UDim2.new(0.5, -newWidth/2, 0.5, -newHeight/2)
	mainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
	if newHeight >= 100 then
		sidebar.Visible = true
		content.Visible = true
	end
	local headerH = math.max(38, math.min(40, math.floor(newHeight * 38 / 600)))
	header.Size = UDim2.new(1, 0, 0, headerH)
	sidebar.Size = UDim2.new(0, 185, 1, -headerH)
	content.Size = UDim2.new(1, -185, 1, -headerH)
	content.Position = UDim2.new(0, 185, 0, headerH)
	local fontScale = newHeight / 600
	title.TextSize = math.max(12, 13 * fontScale)
	for _, tabData in pairs(tabs) do
		local label = tabData[3]
		if label and label:IsA("TextLabel") then
