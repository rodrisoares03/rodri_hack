local function findKickJoint(character)
	if not character then return nil end

	return character:FindFirstChild("Right Hip", true)
		or character:FindFirstChild("RightHip", true)
		or character:FindFirstChild("Left Hip", true)
		or character:FindFirstChild("LeftHip", true)
end

local function playKickPushAnimation(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local joint = findKickJoint(character)
	if not humanoid or not joint or not joint:IsA("Motor6D") then
		return
	end

	local originalTransform = joint.Transform
	local kickPose = humanoid.RigType == Enum.HumanoidRigType.R15
		and CFrame.Angles(math.rad(-72), 0, math.rad(10))
		or CFrame.Angles(math.rad(68), 0, math.rad(12))

	local tweenOut = TweenService:Create(joint, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Transform = kickPose
	})
	local tweenBack = TweenService:Create(joint, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Transform = originalTransform
	})

	tweenOut:Play()
	tweenOut.Completed:Connect(function()
		tweenBack:Play()
	end)
end

local function getPlayerFromCharacterPart(part)
	if not part then return nil end

	local model = part:FindFirstAncestorOfClass("Model")
	if not model then return nil end

	return Players:GetPlayerFromCharacter(model)
end

local function getKickPushTarget()
	local myChar = LocalPlayer.Character
	local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
	if not myRoot then
		return nil
	end

	local mouse = LocalPlayer:GetMouse()
	local hoveredPlayer = mouse and getPlayerFromCharacterPart(mouse.Target)
	if hoveredPlayer and hoveredPlayer ~= LocalPlayer and hoveredPlayer.Character and isInSameDimension(hoveredPlayer.Character) then
		local hoveredHumanoid = hoveredPlayer.Character:FindFirstChildOfClass("Humanoid")
		local hoveredRoot = hoveredPlayer.Character:FindFirstChild("HumanoidRootPart")
		if hoveredHumanoid and hoveredRoot and hoveredHumanoid.Health > 0 and (hoveredRoot.Position - myRoot.Position).Magnitude <= kickPushMaxDistance then
			return hoveredPlayer
		end
	end

	local camera = workspace.CurrentCamera
	if not camera then
		return nil
	end

	local cursorPos = UserInputService:GetMouseLocation()
	local screenCenter = Vector2.new(camera.ViewportSize.X * 0.5, camera.ViewportSize.Y * 0.5)
	local aimPoint = cursorPos and cursorPos.Magnitude > 0 and cursorPos or screenCenter
	local bestPlayer = nil
	local bestDistance = kickPushScreenRadius

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and isInSameDimension(player.Character) then
			local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
			local targetHumanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
				local worldDistance = (targetRoot.Position - myRoot.Position).Magnitude
				if worldDistance <= kickPushMaxDistance then
					local screenPos, onScreen = camera:WorldToViewportPoint(targetRoot.Position)
					if onScreen and screenPos.Z > 0 then
						local screenDistance = (Vector2.new(screenPos.X, screenPos.Y) - aimPoint).Magnitude
						if screenDistance < bestDistance then
							bestDistance = screenDistance
							bestPlayer = player
						end
					end
				end
			end
		end
	end

	return bestPlayer
end

local function isKickPushTargetValid(targetPlayer)
	if not targetPlayer or targetPlayer == LocalPlayer then
		return false
	end

	local targetCharacter = targetPlayer.Character
	if not targetCharacter or not isInSameDimension(targetCharacter) then
		return false
	end

	local targetRoot = targetCharacter:FindFirstChild("HumanoidRootPart")
	local targetHumanoid = targetCharacter:FindFirstChildOfClass("Humanoid")
	local myCharacter = LocalPlayer.Character
	local myRoot = myCharacter and myCharacter:FindFirstChild("HumanoidRootPart")

	if not targetRoot or not targetHumanoid or not myRoot then
		return false
	end

	if targetHumanoid.Health <= 0 then
		return false
	end

	return (targetRoot.Position - myRoot.Position).Magnitude <= kickPushMaxDistance
end

local function requestKickPushServer(targetPlayer)
	if not targetPlayer or targetPlayer == LocalPlayer then
		return false
	end

	local remote = ReplicatedStorage:FindFirstChild(kickPushRemoteName)
	if remote and remote:IsA("RemoteEvent") then
		remote:FireServer(targetPlayer)
		return true
	end

	if not kickPushMissingRemoteWarned then
		kickPushMissingRemoteWarned = true
		warn("[NIGHT MENU] RemoteEvent '" .. kickPushRemoteName .. "' nao encontrado. O empurrao precisa de servidor para funcionar.")
	end

	return false
end

local kickPushIsExecuting = false

function performKickPush(targetPlayer)
	if kickPushIsExecuting then return false end
	if not isKickPushTargetValid(targetPlayer) then return false end
	kickPushIsExecuting = true

	local myChar = LocalPlayer.Character
	if not myChar then return false end

	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	local myHumanoid = myChar:FindFirstChildOfClass("Humanoid")
	local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
	local targetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")

	if not myRoot or not myHumanoid or not targetRoot or not targetHumanoid then return false end
	if myHumanoid.Health <= 0 or targetHumanoid.Health <= 0 then return false end
	if not isInSameDimension(targetPlayer.Character) then return false end

	local origin = myRoot.Position
	local direction = targetRoot.Position - origin
	if direction.Magnitude < 0.1 then
		direction = myRoot.CFrame.LookVector
	end
	direction = direction.Unit
	local distance = (targetRoot.Position - origin).Magnitude
	if distance > kickPushMaxDistance then
		return false
	end

	playKickPushAnimation(myChar)

	local savedCFrame = myRoot.CFrame
	local savedVelocity = myRoot.AssemblyLinearVelocity
	local savedAngularVelocity = myRoot.AssemblyAngularVelocity
	local savedAutoRotate = myHumanoid.AutoRotate
	local savedPlatformStand = myHumanoid.PlatformStand
	local savedPhysicalProps = myRoot.CustomPhysicalProperties
	local savedParts = {}
	forEachCharacterPart(myChar, function(part)
		savedParts[part] = part.CanCollide
		if part.Name ~= "HumanoidRootPart" then
			part.CanCollide = false
		end
	end)
	if myRoot then
		myRoot.CanCollide = true
		myRoot.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5)
	end

	-- Bypass de CollisionGroup: jogos que desabilitam colisao entre players bloqueiam o Fling
	local flingCollider = Instance.new("Part")
	flingCollider.Name = "FlingCollider"
	flingCollider.Size = Vector3.new(2, 2, 2)
	flingCollider.Transparency = 1
	flingCollider.CanCollide = true
	flingCollider.Massless = true
	flingCollider.CollisionGroup = "Default"
	flingCollider.CFrame = myRoot.CFrame
	flingCollider.Parent = myChar

	local flingWeld = Instance.new("WeldConstraint")
	flingWeld.Part0 = myRoot
	flingWeld.Part1 = flingCollider
	flingWeld.Parent = flingCollider

	myHumanoid.AutoRotate = false
	myHumanoid.PlatformStand = false
	myHumanoid.Sit = false
	myHumanoid:ChangeState(Enum.HumanoidStateType.Physics)

	local flingStart = tick()
	local flingConnection
	flingConnection = RunService.Heartbeat:Connect(function()
		local elapsed = tick() - flingStart
		if elapsed >= kickPushFlingTime then
			if flingConnection then
				flingConnection:Disconnect()
			end
			return
		end

		if not targetPlayer.Character then
			if flingConnection then
				flingConnection:Disconnect()
			end
			return
		end

		local liveTargetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
		local liveTargetHumanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
		if not liveTargetRoot or not liveTargetHumanoid or liveTargetHumanoid.Health <= 0 then
			if flingConnection then
				flingConnection:Disconnect()
			end
			return
		end

		local liveDirection = liveTargetRoot.Position - myRoot.Position
		local horizontalDirection = Vector3.new(liveDirection.X, 0, liveDirection.Z)
		if horizontalDirection.Magnitude < 0.1 then
			horizontalDirection = Vector3.new(direction.X, 0, direction.Z)
		end
		if horizontalDirection.Magnitude < 0.1 then
			horizontalDirection = Vector3.new(myRoot.CFrame.LookVector.X, 0, myRoot.CFrame.LookVector.Z)
		end
		horizontalDirection = horizontalDirection.Unit

		local rightVector = horizontalDirection:Cross(Vector3.yAxis)
		if rightVector.Magnitude < 0.1 then
			rightVector = Vector3.new(1, 0, 0)
		else
			rightVector = rightVector.Unit
		end

		-- Fling 'Ballerina' Descentralizado (Impede cancelamento nulo em alvos parados)
		-- PosiГ§Гµes perfeitamente sincronizadas (0,0,0) podem fazer a engine anular o impacto. 
		-- Oscilamos a posiГ§ГЈo internamente garantindo hitboxes assimГ©tricos e repelindo o alvo.
		local offset = Vector3.new(1.2, 0, 1.2)
		if math.floor(elapsed * 20) % 2 == 0 then offset = Vector3.new(-1.2, 0, -1.2) end
		local desiredPos = liveTargetRoot.Position + offset
		local desiredCFrame = CFrame.new(desiredPos)
		
		local spin = 50000 
		local spinVector = Vector3.new(0, spin, 0) 
		-- Velocity ZERO para o seu player! Evita que voce seja lancado para cima
		local launchVelocity = Vector3.new(0, 0, 0)
		pcall(function()
			myRoot.CFrame = desiredCFrame
			myRoot.AssemblyLinearVelocity = launchVelocity
			myRoot.AssemblyAngularVelocity = spinVector
			myRoot.RotVelocity = spinVector
		end)
	end)

	task.delay(kickPushFlingTime + kickPushRecoveryDelay, function()
		if flingConnection then
			flingConnection:Disconnect()
		end

		pcall(function()
			myRoot.Anchored = true
			myRoot.AssemblyLinearVelocity = Vector3.zero
			myRoot.AssemblyAngularVelocity = Vector3.zero
			myRoot.RotVelocity = Vector3.zero
			myRoot.CFrame = savedCFrame
			if savedPhysicalProps ~= nil then
				myRoot.CustomPhysicalProperties = savedPhysicalProps
			else
				myRoot.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
			end
			
			local collider = myChar:FindFirstChild("FlingCollider")
			if collider then collider:Destroy() end
			
			task.delay(0.1, function()
				if myRoot and myRoot.Parent then
					myRoot.AssemblyLinearVelocity = Vector3.zero
					myRoot.AssemblyAngularVelocity = Vector3.zero
					myRoot.Anchored = false
				end
			end)
		end)

		for part, canCollide in pairs(savedParts) do
			if part and part.Parent then
				part.CanCollide = canCollide
			end
		end

		if myHumanoid and myHumanoid.Parent then
			myHumanoid.AutoRotate = savedAutoRotate
			myHumanoid.PlatformStand = savedPlatformStand
			myHumanoid.Sit = false
			myHumanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
		kickPushIsExecuting = false
	end)

	return true
end

