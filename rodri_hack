-- ========= SISTEMA DE BIND DE CHARACTER =========
function bindCharacter(player, character)
	local data = ESPData[player]
	if not data then return end
	if not character or not character.Parent then return end

	data.character = character
	data.humanoid = character:FindFirstChildOfClass("Humanoid")
	data.root = character:FindFirstChild("HumanoidRootPart") or getPrimaryPart(character)

	if data.init and espEnabled and data.humanoid and data.root then
		data.init(character)
	end
end

local function syncPlayerCharacter(player)
	if player == LocalPlayer then return nil end

	local data = ESPData[player]
	if not data then return nil end

	local character = player.Character
	if not character or not character.Parent then
		if data.character then
			cleanupESPForCharacter(data.character)
		end
		data.character = nil
		data.humanoid = nil
		data.root = nil
		return nil
	end

	if data.character ~= character then
		if data.character and data.character ~= character then
			cleanupESPForCharacter(data.character)
		end
		bindCharacter(player, character)
	end

	data.character = character
	data.humanoid = character:FindFirstChildOfClass("Humanoid")
	data.root = character:FindFirstChild("HumanoidRootPart") or getPrimaryPart(character)

	if not data.humanoid or not data.root then
		task.spawn(function()
			for _ = 1, 40 do
				if ESPData[player] ~= data or player.Character ~= character or not character.Parent then
					return
				end

				data.humanoid = character:FindFirstChildOfClass("Humanoid")
				data.root = character:FindFirstChild("HumanoidRootPart") or getPrimaryPart(character)

				if data.humanoid and data.root then
					if data.init and espEnabled then
						data.init(character)
					end
					return
				end

				task.wait(0.15)
			end
		end)
	end

	return data
end

function setupPlayer(player)
	if player == LocalPlayer then return end

	if ESPData[player] and ESPData[player].connections then
		for _, conn in ipairs(ESPData[player].connections) do
			if conn then
				conn:Disconnect()
			end
		end
	end

	ESPData[player] = {
		character = nil,
		humanoid = nil,
		root = nil,
		connections = {},

		init = function(character)
			ensureHighlight(character)
			ensureBox3D(character)
			if showHealth then
				ensureHealthBar(character)
			end
		end,

		hide = function()
			local char = player.Character
			if not char then return end
			
			if highlights[char] then
				highlights[char].Enabled = false
			end
			if overlays[char] then
				overlays[char].Enabled = false
			end
			if boxes[char] then
				pcall(function() boxes[char]:Destroy() end)
				boxes[char] = nil
			end
			if nameLabels[char] then
				nameLabels[char].Visible = false
			end
			if distanceLabels[char] then
				distanceLabels[char].Visible = false
			end
		end,

		cleanup = function()
			local char = ESPData[player] and ESPData[player].character
			if char then
				pcall(function()
					if highlights[char] then
						highlights[char]:Destroy()
						highlights[char] = nil
					end
					if overlays[char] then
						overlays[char]:Destroy()
						overlays[char] = nil
					end
					if boxes[char] then
						pcall(function() boxes[char]:Destroy() end)
						boxes[char] = nil
					end
					if tracers[char] then
						tracers[char]:Remove()
						tracers[char] = nil
					end
					if nameLabels[char] then
						nameLabels[char]:Remove()
						nameLabels[char] = nil
					end
					if distanceLabels[char] then
						distanceLabels[char]:Remove()
						distanceLabels[char] = nil
					end
				end)
			end
		end
	}

	table.insert(ESPData[player].connections, player.CharacterAdded:Connect(function(character)
		local data = ESPData[player]
		if not data then return end
		if data.character and data.character ~= character then
			cleanupESPForCharacter(data.character)
		end
		bindCharacter(player, character)
		task.defer(function()
			syncPlayerCharacter(player)
		end)
	end))

	table.insert(ESPData[player].connections, player.CharacterRemoving:Connect(function(character)
		local data = ESPData[player]
		if not data then return end
		local oldCharacter = character or data.character
		if oldCharacter then
			cleanupESPForCharacter(oldCharacter)
		end
		data.character = nil
		data.humanoid = nil
		data.root = nil
	end))

	if player.Character then
		syncPlayerCharacter(player)
	end
end

