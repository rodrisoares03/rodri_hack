			UI_Tween(tabLabel, {TextColor3 = C.TxtWhite}, 0.15)
			UI_Tween(tabIcon, {TextColor3 = C.TxtWhite}, 0.15)
		end
	end)
	tab.MouseLeave:Connect(function()
