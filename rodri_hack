		Position = state and UDim2.new(0, 17, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
		Size = UDim2.new(0, 18, 0, 18),
	}, track)
	Corner(9, circle)

	local inlineHint
	if hasDescription then
