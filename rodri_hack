			TextColor3 = Color3.fromRGB(242, 242, 246),
			TextSize = 14,
			TextWrapped = false,
			TextXAlignment = Enum.TextXAlignment.Center,
			TextYAlignment = Enum.TextYAlignment.Center,
			Visible = false,
			ZIndex = 10000030,
		}, gui)
		Corner(6, inlineHint)
		local hintStroke = Stroke(Color3.fromRGB(32, 28, 40), 1, inlineHint)
		hintStroke.Transparency = 0.2
		hintStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	end

	local btn = New("TextButton", {
		Name = "ToggleButton",
		BackgroundTransparency = 1,
		Text = "",
		Size = UDim2.new(1, 0, 1, 0),
	}, f)

	local function applyToggleVisuals(animated)
		local trackPos = state and UDim2.new(0, 19, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
		local frameStrokeTransparency = state and 0 or 0.2
		local frameStrokeColor = state and C.PurpleLine or C.Divider
		if animated then
			UI_Tween(track, {BackgroundColor3 = state and C.ToggleOn or C.ToggleOff}, 0.2)
			UI_Tween(trackStroke, {Color = state and C.Purple or C.Divider, Transparency = 0.15}, 0.2)
			UI_Tween(circle, {Position = trackPos}, 0.22, Enum.EasingStyle.Quad)
			UI_Tween(stroke, {Transparency = frameStrokeTransparency, Color = frameStrokeColor}, 0.2)
		else
			track.BackgroundColor3 = state and C.ToggleOn or C.ToggleOff
			trackStroke.Color = state and C.Purple or C.Divider
			trackStroke.Transparency = 0.15
			circle.Position = trackPos
			stroke.Transparency = frameStrokeTransparency
			stroke.Color = frameStrokeColor
		end
		f:SetAttribute("ToggleState", state)
	end

	local function refreshBindTag()
		if not bindTag then
			return
		end
		local bindName = options.getBindName and options.getBindName() or ""
		local shown = bindName
		if not shown or shown == "" or shown == "None" then
			shown = "--"
			bindTag.TextColor3 = C.TxtDim
		else
			if #shown > 6 then
				shown = shown:sub(1, 6)
			end
			bindTag.TextColor3 = C.TxtWhite
		end
		bindTag.Text = shown
	end

	local function toggleState()
		state = not state
		applyToggleVisuals(true)
		if callback then callback(state) end
	end

	local function setState(newState, invokeCallback)
		if state == newState then
			return
		end
		state = newState
		applyToggleVisuals(true)
		if invokeCallback and callback then
			callback(state)
		end
	end

	btn.MouseButton1Click:Connect(function()
		toggleState()
	end)

	btn.MouseEnter:Connect(function()
		if inlineHint and panelVisible and mainFrame.Visible and not menuIsMinimized then
			hideAllInlineHints()
			local hintWidth = 320
			local hintHeight = 24
			local cardPos = f.AbsolutePosition
			local cardSize = f.AbsoluteSize
			local menuPos = mainFrame and mainFrame.AbsolutePosition or Vector2.new(0, 0)
			local menuSize = mainFrame and mainFrame.AbsoluteSize or Vector2.new(0, 0)
			local menuRight = menuPos.X + menuSize.X
			local desiredX = cardPos.X + math.floor(cardSize.X * 0.42)
			local desiredY = cardPos.Y + cardSize.Y + 6
			local maxInsideRight = menuRight - hintWidth - 10

			if desiredX > maxInsideRight then
				desiredX = menuRight - hintWidth + 40
			end

			inlineHint.Position = UDim2.new(0, desiredX, 0, desiredY)
			inlineHint.Visible = true
			activeInlineHints[inlineHint] = true
		end
	end)

	btn.MouseLeave:Connect(function()
		if inlineHint then
			inlineHint.Visible = false
			activeInlineHints[inlineHint] = nil
		end
	end)

	if hasBindGear then
		toggleBindActions[options.bindId] = function()
			toggleState()
		end
		toggleBindGetters[options.bindId] = options.getBindValue

		gearBtn.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton2 then
				return
			end
			hideAllInlineHints()
			hideAllBindHints()
			local gearPos = gearBtn.AbsolutePosition
			local gearSize = gearBtn.AbsoluteSize
			bindHint.Text = "Press a key/button for " .. text .. " | Esc clears"
			bindHint.Position = UDim2.new(0, gearPos.X - 180, 0, gearPos.Y + gearSize.Y + 8)
			bindHint.Visible = true
			activeBindHints[bindHint] = true
			activeBindCapture = {
				bindId = options.bindId,
				hint = bindHint,
				gear = gearBtn,
				setBind = options.setBind,
				waitingForNextInput = true,
				refreshBindTag = refreshBindTag,
			}
			gearBtn.TextColor3 = C.PurpleGlow
			if bindTag then
				bindTag.BackgroundColor3 = C.BindActive
			end
		end)
	end

	applyToggleVisuals(false)
	refreshBindTag()
	if options.onReady then
		options.onReady({
			setState = setState,
			getState = function() return state end,
			toggle = toggleState,
		})
	end
	return f
end

UserInputService.InputBegan:Connect(function(input, processed)
	if activeBindCapture then
		if activeBindCapture.waitingForNextInput then
			activeBindCapture.waitingForNextInput = false
			return
		end
		local bindValue, bindName = getBindableInput(input)
		if input.KeyCode == Enum.KeyCode.Escape then
			activeBindCapture.setBind(nil, "None")
		elseif bindValue then
			activeBindCapture.setBind(bindValue, bindName)
		end
		if activeBindCapture.hint then
			activeBindCapture.hint.Visible = false
			activeBindHints[activeBindCapture.hint] = nil
		end
		if activeBindCapture.gear then
			activeBindCapture.gear.TextColor3 = C.TxtMid
		end
		if activeBindCapture.refreshBindTag then
			activeBindCapture.refreshBindTag()
		end
		local captureHint = activeBindCapture.hint
		if captureHint and captureHint.Parent then
			captureHint.Visible = false
		end
		local captureGear = activeBindCapture.gear
		if captureGear and captureGear.Parent then
			local parentFrame = captureGear.Parent
			local tag = parentFrame and parentFrame:FindFirstChild("BindTag")
			if tag then
				tag.BackgroundColor3 = C.BindBg
			end
		end
		activeBindCapture = nil
		return
	end

	if isTypingInSearch then
		return
	end

	for bindId, getBindValue in pairs(toggleBindGetters) do
		local bindValue = getBindValue and getBindValue()
		if bindValue and inputMatchesBind(input, bindValue) then
			local action = toggleBindActions[bindId]
			if action then
				action()
				return
			end
		end
	end

	if processed then
		return
	end
end)

local function makeToggleBindSetters(bindValueRef, bindNameRef)
	return function(bindValue, bindName)
		_G[bindValueRef] = bindValue
		_G[bindNameRef] = bindDisplayName(bindValue, bindName)
	end
end

