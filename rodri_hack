local function getBindableInput(input)
	if not input then return nil, nil end

	if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode then
		return input.KeyCode, input.KeyCode.Name
	elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
		return "MouseLeft", "MouseLeft"
	elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
		return "MouseRight", "MouseRight"
	elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
		return "MouseMiddle", "MouseMiddle"
	elseif input.UserInputType == Enum.UserInputType.MouseButton4 then
		return "MouseButton4", "MouseButton4"
	elseif input.UserInputType == Enum.UserInputType.MouseButton5 then
		return "MouseButton5", "MouseButton5"
	end

	return nil, nil
end

local function inputMatchesBind(input, bindValue)
	if not input or not bindValue then return false end

	if typeof(bindValue) == "EnumItem" then
		return input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == bindValue
	elseif bindValue == "MouseLeft" then
		return input.UserInputType == Enum.UserInputType.MouseButton1
	elseif bindValue == "MouseRight" then
		return input.UserInputType == Enum.UserInputType.MouseButton2
	elseif bindValue == "MouseMiddle" then
		return input.UserInputType == Enum.UserInputType.MouseButton3
	elseif bindValue == "MouseButton4" then
		return input.UserInputType == Enum.UserInputType.MouseButton4
	elseif bindValue == "MouseButton5" then
		return input.UserInputType == Enum.UserInputType.MouseButton5
	end

	return false
end

local function bindDisplayName(bindValue, fallbackName)
	if typeof(bindValue) == "EnumItem" then
		return bindValue.Name
	end

	return fallbackName or tostring(bindValue)
end

